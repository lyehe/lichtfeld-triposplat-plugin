body {
    font-family: Inter;
    font-size: 10dp;
}

#content-wrap,
#content-wrap * {
    font-family: Inter;
}

.panel-title {
    display: block;
    font-size: 12dp;
    font-weight: bold;
    margin-bottom: 2dp;
}

.panel-subtitle {
    display: block;
    font-size: 9dp;
    margin-bottom: 6dp;
    line-height: 1.35;
}

.section-title {
    display: block;
    font-size: 10dp;
    font-weight: bold;
    margin-bottom: 4dp;
    margin-top: 4dp;
}

.section-header {
    display: flex;
    align-items: center;
    padding: 5dp 4dp;
    margin-top: 4dp;
    margin-bottom: 2dp;
    line-height: 1.4;
    cursor: pointer;
    font-weight: bold;
}

.section-content {
    padding-top: 4dp;
    padding-bottom: 2dp;
}

.section-content.collapsed {
    display: none;
}

/* Per-image row inside the expandable image list. Each row is clickable
   to toggle its selection; no checkbox widget — we render [x]/[ ] inline
   because RmlUi inputs inside a data-for loop can't round-trip individual
   item state back through our Python bind_func list-returning getter. */
.image-row {
    padding: 2dp 4dp;
    line-height: 1.3;
    font-size: 9dp;
    cursor: pointer;
}

.image-row:hover {
    background: #2c2c2c;
}

.section-arrow {
    width: 12dp;
    margin-right: 6dp;
    line-height: 1.4;
}

.help-text {
    display: block;
    font-size: 9dp;
    margin-bottom: 4dp;
    line-height: 1.35;
}

.setting-row {
    margin-bottom: 5dp;
    line-height: 1.4;
}

.prop-label {
    width: 110dp;
    min-width: 110dp;
    max-width: 110dp;
}

.setting-row > .setting-slider,
.setting-row > select,
.setting-row > input[type="text"] {
    flex: 1;
    min-width: 0;
}

.slider-value {
    width: 52dp;
    min-width: 52dp;
    margin-left: 8dp;
    text-align: right;
    flex-shrink: 0;
}

.setting-label {
    display: flex;
    align-items: center;
}

.button-row {
    display: flex;
    margin-top: 4dp;
    margin-bottom: 4dp;
}

.button-row > .btn {
    flex: 1;
    margin-right: 4dp;
}

.button-row > .btn:last-child {
    margin-right: 0;
}

.action-btn {
    margin-top: 4dp;
    margin-bottom: 4dp;
}

.status-line,
.result-line,
.error-detail {
    display: block;
    margin-bottom: 4dp;
    word-break: break-all;
}

.progress-wrap {
    position: relative;
    margin-bottom: 4dp;
}

.job-progress {
    width: 100%;
    height: 16dp;
}

.progress-text {
    display: block;
    text-align: right;
    margin-top: 2dp;
    font-size: 9dp;
}

.status-error {
    display: block;
    color: #ff6b6b;
    font-size: 10dp;
    margin-bottom: 4dp;
}

.log-box {
    padding: 8dp;
    border-radius: 6dp;
    background: rgba(255, 255, 255, 0.04);
    max-height: 220dp;
    overflow: auto;
}

.model-banner {
    padding: 8dp;
    margin: 4dp 0;
    border-radius: 6dp;
    background: rgba(84, 170, 255, 0.10);
}

.model-banner.banner-warn {
    background: rgba(240, 190, 90, 0.12);
}

.log-output {
    display: block;
    font-size: 8.5dp;
    line-height: 1.35;
    white-space: pre-wrap;
}

.preview-wrap {
    margin: 4dp 0 8dp 0;
    display: flex;
    justify-content: center;
}
